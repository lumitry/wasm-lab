{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Punchy",
            "type": "shell",
            "command": "cp .wasm/index.* punchy/ && cd punchy/ && rustup override set 1.78.0 && rustup target add wasm32-unknown-unknown --toolchain 1.78.0"
        },
        {
            "label": "Serve Punchy",
            "type": "shell",
            "command": "trunk serve --release",
            "options": {
                "cwd": "${workspaceFolder}/punchy"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Setup Punchy",
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^(.*)$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "starting server",
                    "endsPattern": "server listening at"
                }
            }
        },
        {
            "label": "Setup Jumpy",
            "type": "shell",
            "command": "cp .wasm/index.* jumpy/ && cd jumpy/ && rustup target add wasm32-unknown-unknown"
        },
        {
            "label": "Serve Jumpy",
            "type": "shell",
            "command": "trunk serve --release",
            "options": {
                "cwd": "${workspaceFolder}/jumpy"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": "Setup Jumpy",
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^(.*)$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "starting server",
                    "endsPattern": "server listening at"
                }
            }
        },
        {
            "label": "CMake Patch",
            "type": "shell",
            "command": "sed -i 's/,--as-needed//g' CMakeLists.txt",
            "options": {
                "cwd": "${workspaceFolder}/insert-here"
            }
        },
        {
            "label": "mkdir",
            "type": "shell",
            "command": "mkdir -p build-wasm",
            "options": {
                "cwd": "${workspaceFolder}/insert-here"
            },
            "dependsOn": "CMake Patch"
        },
        {
            "label": "CMake",
            "type": "shell",
            "command": "emcmake cmake .. -DCMAKE_C_FLAGS='-pthread' -DCMAKE_CXX_FLAGS='-pthread'",
            "options": {
                "cwd": "${workspaceFolder}/insert-here/build-wasm"
            },
            "dependsOn": "mkdir"
        },
        {
            "label": "Compile CMake",
            "type": "shell",
            "command": "emmake make",
            "options": {
                "cwd": "${workspaceFolder}/insert-here/build-wasm"
            },
            "dependsOn": "CMake",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Serve CMake",
            "type": "shell",
            "command": "python3 ../../.wasm/serve.py",
            "options": {
                "cwd": "${workspaceFolder}/insert-here/build-wasm"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^(.*)$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Serving HTTP",
                    "endsPattern": "Serving HTTP"
                }
            }
        }
    ]
}